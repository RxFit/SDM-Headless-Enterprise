# ═══════════════════════════════════════════════
# ANC-MCP NODE CONFIGURATION
# Copy to .env and fill in values before running.
# ═══════════════════════════════════════════════

# --- NODE IDENTITY ---
NODE_NAME=stripe-node
NODE_DOMAIN=billing
ORCHESTRATOR_TOPIC=jade-commands

# --- POSTGRESQL (Per-Node Schema) ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=antigravity_brain
PG_WRITE_USER=stripe_node_rw
PG_WRITE_PASSWORD=

# --- GOOGLE CLOUD PUB/SUB ---
# Path to GCP service account key (Layer 1 — static, Pub/Sub-only permissions)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-sa-key.json
GCP_PROJECT_ID=

# --- GITHUB DIRECTIVES ---
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_DIRECTIVES_PATH=directives/stripe-node

# --- HEARTBEAT ---
HEARTBEAT_INTERVAL_MS=30000
