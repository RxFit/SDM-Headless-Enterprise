# SDM Headless Enterprise — Environment Variables
# Copy to .env and fill in values

# ─── Core ───────────────────────────────────────────
PORT=8090
NODE_ENV=production
SDM_API_KEY=sdm-enterprise-key-2026

# ─── Public URL (for WebSocket clients) ─────────────
SDM_API_URL=https://ops.rxfit.ai

# ─── Git Sync (optional) ────────────────────────────
GIT_AUTO_SYNC=false
GIT_REMOTE_URL=https://github.com/DanielTrejo14/SDM-Headless-Enterprise.git

# ─── Google Sheets Sync (optional) ──────────────────
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_PATH=

# ─── Concierge Integration ───────────────────────────
CONCIERGE_API_URL=
CONCIERGE_API_KEY=

# ─── Notifications ─────────────────────────────────
NOTIFICATION_EMAIL=
GOOGLE_CHAT_WEBHOOK=

# ─── Cloudflare Tunnel ─────────────────────────────
TUNNEL_ID=d41f8ac1-REPLACE-WITH-REAL-ID
