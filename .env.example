# SDM Headless Enterprise — Environment Configuration
# Copy this to .env and fill in your values

# API Authentication
SDM_API_KEY=your-secure-api-key-here

# Server
PORT=8090
NODE_ENV=production

# Google Sheet Bidirectional Sync
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Tasks
GOOGLE_SHEET_PROXY_URL=

# Notifications
GOOGLE_CHAT_WEBHOOK=
EMAIL_SENDER=

# Concierge Integration
CONCIERGE_API_URL=https://rxfit-concierge.replit.app
CONCIERGE_API_KEY=

# Git Auto-Sync (commit batching)
GIT_AUTO_SYNC=true
GIT_SYNC_INTERVAL_MS=30000
